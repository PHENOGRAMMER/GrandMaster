# ♟️ GrandMaster Chess - Environmental Variables Example

# Secret key for Flask sessions
# SECRET_KEY=your_secret_key_here

# Database URL (automatically provided by Render/Railway Postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/db_name

# Port (assigned automatically by hosting platforms)
PORT=5000

# Email Verification (Set to true to verify new accounts)
EMAIL_ENABLED=false

# SMTP Configurations (Required if EMAIL_ENABLED=true)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=GrandMaster Chess <your_email@gmail.com>
